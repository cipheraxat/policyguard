# PolicyGuard — environment variable overrides
# Copy this file to .env and adjust as needed.

# Profiles: stub | lmstudio | openrouter
POLICYGUARD_PROFILE=stub

DATABASE_URL=postgresql+psycopg://policyguard:policyguard@localhost:5432/policyguard
REDIS_URL=redis://localhost:6379/0

# Optional: disable in-process PII redaction (default false — regex detector always on)
# POLICYGUARD_PII_STUB=true

# LM Studio / OpenAI-compatible
# POLICYGUARD_CHAT_BASE_URL=http://host.docker.internal:1234/v1
# POLICYGUARD_CHAT_MODEL=local-model
# POLICYGUARD_EMBEDDING_BASE_URL=http://host.docker.internal:1234/v1
# POLICYGUARD_EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1.5
# POLICYGUARD_EMBEDDING_DIM=1536

# OpenRouter
# POLICYGUARD_CHAT_BASE_URL=https://openrouter.ai/api/v1
# POLICYGUARD_CHAT_API_KEY=sk-or-...
# POLICYGUARD_CHAT_MODEL=anthropic/claude-3-haiku

# Reviewer allow-list (empty = dev mode)
# POLICYGUARD_REVIEWERS_ALLOWED_IDS=["alice","bob"]
