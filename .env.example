# PolicyGuard — environment variable overrides
# Copy this file to .env and adjust as needed.
# docker-compose will automatically load .env from the project root.

# ── Presidio ──────────────────────────────────────────────────────────────────
# If mcr.microsoft.com/presidio-analyzer is not accessible in your environment,
# change this to the community image: presidio-analyzer:latest
# (Note: the community image may have a different API surface on port 5001/5002)
PRESIDIO_IMAGE=mcr.microsoft.com/presidio-analyzer:latest

# ── LLM provider selection (also set spring.profiles.active) ─────────────────
# Profiles: lmstudio | openrouter | openai | stub
# LLM_PROVIDER=lmstudio

# ── OpenRouter (hosted chat) ──────────────────────────────────────────────────
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=anthropic/claude-3-haiku

# ── OpenAI (direct) ───────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── LMStudio (local, default) ─────────────────────────────────────────────────
# LMSTUDIO_BASE_URL=http://host.docker.internal:1234/v1
# LMSTUDIO_EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1.5
# Ensure embedding dim matches policyguard.embedding.dim (default 1536)

# ── Postgres ──────────────────────────────────────────────────────────────────
# POSTGRES_USER=policyguard
# POSTGRES_PASSWORD=policyguard
# POSTGRES_DB=policyguard
